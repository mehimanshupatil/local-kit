---
import ThemeToggle from './ThemeToggle';
import { categories } from '../../data/tools';
import Icon from '../ui/Icon';
import {Menu, ChevronDown, Shield} from 'lucide-react'
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-gray-950/90 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-base text-gray-900 dark:text-white hover:text-brand-600 dark:hover:text-brand-400 transition-colors shrink-0">
      <img src="/icon.svg" alt="LocalKit" class="w-7 h-7 rounded-lg" />
      <span class="hidden sm:block">LocalKit</span>
    </a>

    <!-- Desktop nav with dropdowns -->
    <nav class="hidden md:flex items-center gap-1 flex-1 justify-center">
      {categories.map(cat => {
        const isActive = currentPath.startsWith(cat.href);
        return (
          <div class="relative group">
            <a
              href={cat.href}
              class:list={[
                'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all',
                isActive
                  ? 'text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-950/40'
                  : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800',
              ]}
            >
        <Icon icon={cat.icon} size={20} />
        {cat.title.replace(' Tools', '')}
               <ChevronDown className="size-3.5 opacity-50 -mr-0.5"/>
            </a>

            <!-- Dropdown -->
            <div class="absolute top-full left-0 mt-1.5 w-52 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-lg py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 translate-y-1 group-hover:translate-y-0">
              {cat.tools.map(tool => (
                <a
                  href={tool.href}
                  class:list={[
                    'block px-4 py-2 text-sm transition-colors',
                    currentPath === tool.href
                      ? 'text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-950/30 font-medium'
                      : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-gray-100',
                  ]}
                >
                  {tool.name}
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2 shrink-0">
      <!-- Privacy badge -->
      <span class="hidden lg:flex items-center gap-1.5 text-xs text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-950/40 px-2.5 py-1 rounded-full font-medium border border-green-200 dark:border-green-900">
        <Shield className="size-3" />
        
        100% Private
      </span>

      <ThemeToggle client:load />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        
        <Menu className="size-5 "/>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
    {categories.map(cat => (
      <div class="px-4 py-3">
        <a href={cat.href} class="flex items-center gap-2 text-sm font-semibold text-gray-900 dark:text-white mb-2">
               <Icon icon={cat.icon} size={20} />
           {cat.title}
        </a>
        <div class="grid grid-cols-2 gap-1 pl-2">
          {cat.tools.map(tool => (
            <a
              href={tool.href}
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 py-1 transition-colors"
            >
              {tool.name}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
