---
import { categories } from "../../data/tools";
import { FcFlashOn } from "react-icons/fc";
import Icon from "../ui/Icon";
import { Shield } from "lucide-react";
---

<footer
  class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16"
>
  <!-- Main footer grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 sm:col-span-1 space-y-4">
        <a
          href="/"
          class="flex items-center gap-2 font-bold text-gray-900 dark:text-white"
        >
          <img src="/icon.svg" alt="LocalKit" class="w-7 h-7 rounded-lg" />
          LocalKit
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
          Free, privacy-first file tools. Everything runs in your browser — no
          uploads, no servers.
        </p>
        <div class="flex flex-wrap gap-2">
          <span
            class="inline-flex items-center gap-1 text-xs text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-950/40 px-2.5 py-1 rounded-full border border-green-200 dark:border-green-900"
          >
            <Shield className="size-3" />
            100% Private
          </span>
          <span
            class="inline-flex items-center gap-1 text-xs text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-950/40 px-2.5 py-1 rounded-full border border-blue-200 dark:border-blue-900"
          >
            <Icon icon={FcFlashOn} size={12} className="m-auto" />

            WASM Powered
          </span>
        </div>
      </div>

      <!-- Tool columns -->
      {
        categories.map((cat) => (
          <div class="space-y-3">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
              {cat.title}
            </h3>
            <ul class="space-y-2">
              {cat.tools.map((tool) => (
                <li>
                  <a
                    href={tool.href}
                    class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
                  >
                    {tool.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-200 dark:border-gray-800">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-400 dark:text-gray-500"
    >
      <p>
        © {new Date().getFullYear()} LocalKit — Open source, privacy-first browser
        utilities
      </p>
      <div class="flex items-center gap-4">
        <a
          href="/faq"
          class="hover:text-brand-500 dark:hover:text-brand-400 transition-colors"
          >FAQ</a
        >
        <a
          href="/privacy"
          class="hover:text-brand-500 dark:hover:text-brand-400 transition-colors"
          >Privacy</a
        >
        <a
          href="https://github.com/mehimanshupatil/local-kit"
          class="hover:text-brand-500 dark:hover:text-brand-400 transition-colors flex items-center gap-1"
        >
          <svg
            class="w-4 h-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path></svg
          >
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
