---
import '../styles/global.css';
import ToasterProvider from '../components/layout/ToasterProvider';
import PWAInstallPrompt from '../components/layout/PWAInstallPrompt';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
}

const { title, description, canonicalURL } = Astro.props;
const siteURL = 'https://localkit.app';
const fullTitle = title.includes('LocalKit') ? title : `${title} | LocalKit`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    {canonicalURL && <link rel="canonical" href={`${siteURL}${canonicalURL}`} />}

    <!-- OG -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalURL && <meta property="og:url" content={`${siteURL}${canonicalURL}`} />}

    <!-- Favicon & PWA -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/icon.svg" sizes="any" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" />
    <meta name="theme-color" content="#0284c7" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Theme: prevents flash -->
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <slot />
    <ToasterProvider client:load />
    <PWAInstallPrompt client:load />
  </body>
</html>
