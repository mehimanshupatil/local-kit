---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { categories } from "../../data/tools";
import Icon from "../../components/ui/Icon";

const cat = categories.find((c) => c.id === "image")!;
---

<BaseLayout
  title={cat.pageTitle}
  description={cat.pageDesc}
  canonicalURL={cat.href}
>
  <Header />
  <main class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <div class="mb-4">
          <Icon icon={cat.icon} size={48} className="m-auto" />
        </div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-3">
          {cat.heading}
        </h1>
        <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
          {cat.subheading}
        </p>
        {
          cat.note && (
            <div class="mt-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-100 dark:bg-amber-950 text-amber-700 dark:text-amber-400 text-sm">
              {cat.note}
            </div>
          )
        }
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-5">
        {
          cat.tools.map((t) => (
            <a
              href={t.href}
              class="card p-6 flex flex-col gap-3 hover:border-brand-400 dark:hover:border-brand-600 hover:shadow-md transition-all group"
            >
              <Icon icon={t.icon} size={28} />
              <div>
                <p class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                  {t.name}
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
                  {t.desc}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
